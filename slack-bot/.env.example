# Slack credentials (from api.slack.com → your app)
SLACK_BOT_TOKEN=xoxb-...          # OAuth & Permissions → Bot User OAuth Token
SLACK_APP_TOKEN=xapp-...          # Basic Information → App-Level Tokens (connections:write)
SLACK_SIGNING_SECRET=...          # Basic Information → Signing Secret

# Anthropic
ANTHROPIC_API_KEY=sk-ant-...

# Postgres — use the Supabase session-pooler URL for the pulse_mcp_ro role
# Format: postgresql://pulse_mcp_ro.<project-ref>:<password>@aws-0-<region>.pooler.supabase.com:5432/postgres
MCP_DATABASE_URL=postgresql://pulse_mcp_ro.<project-ref>:<password>@aws-0-<region>.pooler.supabase.com:5432/postgres
