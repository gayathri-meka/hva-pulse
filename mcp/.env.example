# Read-only Postgres connection string for the pulse_mcp_ro role.
# Use the Supabase SESSION POOLER URL (port 5432), not the direct connection.
# Username format for the pooler: pulse_mcp_ro.[PROJECT_REF]
#
# Get from: Supabase Dashboard → Settings → Database → Connection string → Session mode
# Then replace the username prefix with pulse_mcp_ro
#
# Example:
#   MCP_DATABASE_URL=postgresql://pulse_mcp_ro.abcdefghijklmnop:[PASSWORD]@aws-0-us-east-1.pooler.supabase.com:5432/postgres
MCP_DATABASE_URL=
